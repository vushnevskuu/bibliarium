# PostgreSQL
# Локально (docker compose up -d): без пулера — обе строки одинаковые.
DATABASE_URL="postgresql://bibliarium:bibliarium@127.0.0.1:5432/bibliarium"
DIRECT_URL="postgresql://bibliarium:bibliarium@127.0.0.1:5432/bibliarium"

# Supabase (из Dashboard → Connect → ORM → Prisma): пулер + direct для migrate
# DATABASE_URL="postgresql://postgres.PROJECT_REF:[PASSWORD]@...pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.PROJECT_REF:[PASSWORD]@...pooler.supabase.com:5432/postgres"

# Supabase (Auth) — https://supabase.com/dashboard
# На Vercel достаточно любой пары (вторая — без NEXT_PUBLIC_, читается на сервере в рантайме):
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"

# Canonical URL for SEO / Open Graph (production domain)
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# OpenAI — for vision analysis (image aesthetics) + YouTube transcript summaries + taste profile
# Without this key the AI profile still works but without visual descriptions.
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
