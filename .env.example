# Local dev (default): SQLite file next to prisma/schema.prisma
DATABASE_URL="file:./dev.db"

# Supabase (Auth) — create a project at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Optional fallback when Host is missing. `npm run dev` uses port 3333 — for copy-paste exports in dev:
# NEXT_PUBLIC_APP_URL="http://127.0.0.1:3333"
# Production:
# NEXT_PUBLIC_APP_URL="https://bibliarium.example.com"

# Production: PostgreSQL / Supabase (requires switching prisma/schema.prisma provider to postgresql)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
